# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Optional: Alpha Vantage (news / fundamentals / prices when you set data_vendors to alpha_vantage)
#ALPHA_VANTAGE_API_KEY=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
# Append-only learned rules (after a pending decision gets returns + reflection):
#TRADINGAGENTS_LEARNED_RULES_ENABLED=true
# Optional path; default is learned_rules.md next to TRADINGAGENTS_MEMORY_LOG_PATH
#TRADINGAGENTS_LEARNED_RULES_PATH=
# After each successful full analysis, POST advisory text (Slack-style JSON) — not an order:
#TRADINGAGENTS_ANALYSIS_WEBHOOK_URL=
# Optional: email the advisory memo after each successful full analysis (SMTP).
#TRADINGAGENTS_ANALYSIS_EMAIL_TO=you@gmail.com
#TRADINGAGENTS_ANALYSIS_EMAIL_FROM=
#TRADINGAGENTS_SMTP_HOST=smtp.gmail.com
#TRADINGAGENTS_SMTP_PORT=587
#TRADINGAGENTS_SMTP_USER=you@gmail.com
#TRADINGAGENTS_SMTP_PASSWORD=
#TRADINGAGENTS_SMTP_USE_TLS=true

# Portfolio advisor (init/replan = LLM schedule; weekly = light check; run-due = deep graph)
# First run:  python -m cli.main advisor portfolio init
# Weekly light check: scripts/cron-portfolio-advisor-weekly.sh (default weekday 5=Saturday)
# Full replan:     scripts/cron-portfolio-advisor-replan.sh  OR  `advisor portfolio replan`
#TRADINGAGENTS_PORTFOLIO_ADVISOR_WEEKDAY=6
#TRADINGAGENTS_PORTFOLIO_ADVISOR_MAX_JOBS=15
#TRADINGAGENTS_PORTFOLIO_ADVISOR_RUN_DUE_MAX=2
#TRADINGAGENTS_PORTFOLIO_ADVISOR_WEEKLY_LLM=false
#TRADINGAGENTS_PORTFOLIO_ADVISOR_WEEKLY_ALWAYS_EMAIL=true
# Optional: dedicated planner model (default = quick_think_llm). OpenRouter slug example:
#TRADINGAGENTS_PORTFOLIO_ADVISOR_PLANNER_MODEL=google/gemini-2.0-flash-001
# Reasoning model for post-earnings CLI + CRITICAL advisor digests (default deepseek/deepseek-r1):
#TRADINGAGENTS_PORTFOLIO_ADVISOR_REASONING_MODEL=deepseek/deepseek-r1
# Skip replan LLM when ticker set + catalyst digest unchanged (saves cost):
#TRADINGAGENTS_PORTFOLIO_ADVISOR_SKIP_REPLAN_UNCHANGED=false
#TRADINGAGENTS_PORTFOLIO_ADVISOR_EARNINGS_RAMP_DAYS=7
# Skip webhook + advisory email after full graph when rating is Hold:
#TRADINGAGENTS_ANALYSIS_NOTIFY_SUPPRESS_HOLD=false
#TRADINGAGENTS_EVENT_LOG_PATH=~/.tradingagents/memory/events.jsonl
#TRADINGAGENTS_MEMORY_CONTEXT_LOOKBACK_DAYS=90
#TRADINGAGENTS_MEMORY_CONTEXT_MAX_SAME=8
#TRADINGAGENTS_MEMORY_CONTEXT_MAX_CROSS=3
#TRADINGAGENTS_MEMORY_EVENT_LOG_PROMPT_DAYS=30
# Run full graph on every holding right after first `advisor portfolio init` (expensive):
#TRADINGAGENTS_PORTFOLIO_ADVISOR_BOOTSTRAP_ON_INIT=false
#TRADINGAGENTS_PORTFOLIO_ADVISOR_BOOTSTRAP_DELAY=45
#TRADINGAGENTS_PORTFOLIO_ADVISOR_BOOTSTRAP_MAX_POSITIONS=

# eToro Public API (read-only: portfolio + instrument names). Create keys in the
# eToro app: Settings → Trading → API Key Management. Never commit real values.
#
# ETORO_API_KEY → HTTP header x-api-key (the app / “public” integration key eToro shows first).
# ETORO_USER_KEY → HTTP header x-user-key (your personal user key — a different string; if PnL
# returns 401, swap the two lines or regenerate the pair in eToro).
#ETORO_API_KEY=
#ETORO_USER_KEY=
# real (default) or demo — must match the environment the user key was created for
#ETORO_ACCOUNT=real
# Optional override (default https://public-api.etoro.com)
#ETORO_API_BASE=https://public-api.etoro.com

# Clerk automation (optional — see scripts/cron-clerk-*.sh)
# Daily morning clerk is **disabled**; use weekly + optional monthly only.
# Weekly: deep-research queue from triggers; optional execution:
#   CLERK_MODE=etoro
#   CLERK_WEEKLY_EXECUTE_DEEP=1
#   CLERK_WEEKLY_MAX_DEEP=2
# Monthly lookout (copy example JSON and set path):
#   CLERK_MONTHLY_CANDIDATES=/path/to/monthly_candidates.json
#   CLERK_MONTHLY_MAX_DEEP=2
# Webhook for all clerk tiers:
#TRADINGAGENTS_CLERK_WEBHOOK_URL=
