# systemd USER unit - TradingAgents Telegram PM listener.
#
# Install on the server (as ubuntu):
#   cp deploy/telegram-listener-user.service.example ~/.config/systemd/user/tradingagents-telegram-listener.service
#   chmod +x /opt/tradingagents/scripts/run-telegram-listener.sh
#   systemctl --user daemon-reload
#   systemctl --user enable --now tradingagents-telegram-listener.service

[Unit]
Description=TradingAgents Telegram PM Listener
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/tradingagents
Environment=PYTHONPATH=/opt/tradingagents
ExecStart=/opt/tradingagents/scripts/run-telegram-listener.sh
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
